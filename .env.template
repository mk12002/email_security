# =============================================================================
# Agentic Email Security System - Environment Template
# =============================================================================

# --- Application ---
APP_ENV=development
APP_LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=logs/
RUNTIME_BOOTSTRAP_ENABLED=1
RUNTIME_BOOTSTRAP_DECLARE_RESULTS_QUEUE=1
RUNTIME_BOOTSTRAP_REFRESH_IOC=1
RUNTIME_BOOTSTRAP_FORCE_IOC_REFRESH=1

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Messaging ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
NEW_EMAIL_EXCHANGE=email.new.exchange
RESULTS_QUEUE=email.results.queue

# --- Persistence ---
DATABASE_URL=postgresql://postgres:postgres@database:5432/email_security
REDIS_URL=redis://redis:6379/0

# --- Parser ---
EMAIL_DROP_DIR=/mnt/email_drop
ATTACHMENT_VOLUME_DIR=/mnt/attachments
PARSER_POLL_SECONDS=2

# --- Orchestrator finalization controls ---
ORCHESTRATOR_CACHE_TTL_SECONDS=900
ORCHESTRATOR_PARTIAL_TIMEOUT_SECONDS=90
ORCHESTRATOR_MIN_AGENTS_FOR_DECISION=4

# --- Azure OpenAI (only cloud dependency in this architecture) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# --- Threat intel / integrations ---
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
OTX_API_KEY=
ABUSEIPDB_API_KEY=
ENABLE_VIRUSTOTAL_URL_LOOKUP=0
ENABLE_GOOGLE_SAFE_BROWSING_LOOKUP=0
ENABLE_OPENPHISH_LOOKUP=0
ENABLE_URLHAUS_LOOKUP=0
ENABLE_OTX_LOOKUP=0
ENABLE_ABUSEIPDB_LOOKUP=0
ENABLE_MALWAREBAZAAR_LOOKUP=0
ENABLE_VIRUSTOTAL_HASH_LOOKUP=0
EXTERNAL_LOOKUP_TIMEOUT_SECONDS=6
EXTERNAL_LOOKUP_MAX_INDICATORS=10
OPENPHISH_FEED_URL=https://openphish.com/feed.txt
OPENPHISH_CACHE_TTL_SECONDS=900
URLHAUS_API_URL=https://urlhaus-api.abuse.ch/v1/url/
OTX_API_BASE_URL=https://otx.alienvault.com
ABUSEIPDB_API_URL=https://api.abuseipdb.com/api/v2/check
MALWAREBAZAAR_API_URL=https://mb-api.abuse.ch/api/v1/
GARUDA_API_BASE_URL=http://garuda-agent:8088
GARUDA_TIMEOUT_SECONDS=15

# --- Action layer endpoints ---
QUARANTINE_API_URL=http://host.docker.internal:8091/quarantine
SOC_ALERT_API_URL=http://host.docker.internal:8092/alerts

# --- Local IOC DB ---
IOC_DB_PATH=/app/data/ioc_store.db
IOC_REFRESH_SECONDS=300

# --- Sandbox ---
SANDBOX_DETONATION_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT_SECONDS=60
SANDBOX_LOCAL_DOCKER_ENABLED=0
SANDBOX_EXECUTOR_URL=
SANDBOX_EXECUTOR_SHARED_TOKEN=
SANDBOX_EXECUTOR_TIMEOUT_SECONDS=30
SANDBOX_EXECUTOR_ATTACHMENT_ROOT=/mnt/attachments
SANDBOX_ALLOW_NETWORK=0
SANDBOX_NON_ROOT_USER=65534:65534
SANDBOX_MEMORY_LIMIT_MB=256
SANDBOX_PIDS_LIMIT=128
SANDBOX_MAX_DETONATIONS=5
SANDBOX_CLEANUP_STALE_SECONDS=1800
SANDBOX_ENABLE_BENIGN_BOOTSTRAP=1
SANDBOX_BENIGN_BOOTSTRAP_MAX_ROWS=5000
